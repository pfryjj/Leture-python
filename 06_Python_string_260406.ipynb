s = input('알파벳 문자열 입력 :')

result = '' 
for ch in s:
    if ch in ['A', 'a']:
        result += '.- '
    elif ch in ['B', 'b']:
        result += '-... '
    elif ch in ['C', 'c']:
        result += '-.-. '
    elif ch in ['D', 'd']:
        result += '-.. '
    elif ch in ['E', 'e']:
        result += '. '
    elif ch in ['F', 'f']:
        result += '..-. '
    elif ch in ['G', 'g']:
        result += '--. '
    elif ch in ['H', 'h']:
        result += '.... '
    elif ch in ['I', 'i']:
        result += '.. '
    elif ch in ['J', 'j']:
        result += '.--- '
    elif ch in ['K', 'k']:
        result += '-.- '
    elif ch in ['L', 'l']:
        result += '.-.. '
    elif ch in ['M', 'm']:
        result += '-- '
    elif ch in ['N', 'n']:
        result += '-. '
    elif ch in ['O', 'o']:
        result += '--- '
    elif ch in ['P', 'p']:
        result += '.--. '
    elif ch in ['Q', 'q']:
        result += '--.- '
    elif ch in ['R', 'r']:
        result += '.-. '
    elif ch in ['S', 's']:
        result += '... '
    elif ch in ['T', 't']:
        result += '- '
    elif ch in ['U', 'u']:
        result += '..- '
    elif ch in ['V', 'v']:
        result += '...- '
    elif ch in ['W', 'w']:
        result += '.-- '
    elif ch in ['X', 'x']:
        result += '-..- '
    elif ch in ['Y', 'y']:
        result += '-.-- '
    elif ch in ['Z', 'z']:
        result += '--.. '

print('모스부호 :', result)
