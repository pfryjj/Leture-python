   "source": [
    "# 문자열 운용\n",
    "s = input(\"문자열을 입력하세요: \")\n",
    "\n",
    "\n",
    "print(\"strip():\", s.strip())\n",
    "print(\"lstrip():\", s.lstrip())\n",
    "print(\"rstrip():\", s.rstrip())\n",
    "\n",
    "\n",
    "print(\"앞에서 # 제거:\", s.lstrip('#'))\n",
    "print(\"뒤에서 ! 제거:\", s.rstrip('!'))\n",
    "\n",
    "\n",
    "word = input(\"찾을 단어 입력: \")\n",
    "\n",
    "print(\"find():\", s.find(word))\n",
    "print(\"rfind():\", s.rfind(word))\n",
    "print(\"count():\", s.count(word))"
   ]
